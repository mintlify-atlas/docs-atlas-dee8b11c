  "keyFeatures": [
    "Interactive coding challenges (mini-projetos) with GitHub integration",
    "Video workshops with lesson tracking and progress monitoring",
    "Learning tracks (trilhas) combining workshops and challenges",
    "User authentication with GitHub and Discord OAuth",
    "Community features with comments, reactions, and Discord integration",
    "Certificate generation for completed courses",
    "Subscription management with Pro tier features",
    "Video player with Vimeo integration and progress tracking",
    "Real-time collaborative features and social sharing",
    "Dashboard with user progress and statistics"
  ],
  "publicApiSurface": [
    "Challenge - getChallenge(slug), getAllChallenges(), enrollChallenge()",
    "Workshop - getWorkshop(slug), getAllWorkshops(), markLessonComplete()",
    "Track - getTrack(slug), getAllTracks(), getTrackProgress()",
    "User - getCurrentUser(), updateProfile(), getUserStats()",
    "Lesson - getLesson(id), markWatched(), getProgress()",
    "Subscription - getPlans(), subscribe(), cancelSubscription()",
    "Authentication - login(), register(), logout(), requireAuth()",
    "Comments - getComments(), addComment(), deleteComment()",
    "Certificates - getCertificate(id), generateCertificate()",
    "Dashboard - getDashboardData(), getUserProgress()"
  ]
}
